class ReportingAgent:
    """Handles report generation and metric aggregation"""

    name = "ReportingAgent"

    def invoke(self, query: str) -> dict:
        tools_used = ["snowflake_connector", "tableau_api", "dbt_runner"]
        return {
            "agent": self.name,
            "response": f"Generating report: {query[:60]}. Querying Snowflake Gold layer and refreshing Tableau dashboard.",
            "tools_called": tools_used,
            "action": "GENERATE_REPORT",
