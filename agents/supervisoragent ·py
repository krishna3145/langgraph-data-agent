class GeneralAgent:
    """Fallback for unclassified queries"""

    name = "GeneralAgent"

    def invoke(self, query: str) -> dict:
        return {
            "agent": self.name,
            "response": f"Processing general query: {query[:60]}.",
            "tools_called": ["general_knowledge_base"],
            "action": "GENERAL_RESPONSE",
            "result": "Query handled by general fallback agent.",
        }


# ── Supervisor Orchestrator ───────────────────────────────────────────────────

class SupervisorOrchestrator:
    """
    Master orchestrator for multi-agent data engineering system
    Implements: routing → tool invocation → response → observability

    Accenture JD alignment:
    - Policy-based routing: PolicyRouter
    - Tool invocation: per-agent tool_calls
    - Orchestration: SupervisorOrchestrator
    - Lifecycle observability: run_traces
    """

    AGENTS = {
        "DataQualityAgent": DataQualityAgent(),
        "PipelineAgent": PipelineAgent(),
        "AnomalyAgent": AnomalyAgent(),
        "ReportingAgent": ReportingAgent(),
        "GeneralAgent": GeneralAgent(),
    }

    def __init__(self):
        self.router = PolicyRouter()
        self.run_traces: List[AgentState] = []

    def run(self, query: str, session_id: str = None) -> AgentState:
        """Execute full agent pipeline with observability tracing"""
        start = time.time()
        session_id = session_id or str(uuid.uuid4())[:8]

        # Step 1: Policy routing
        routing = self.router.route(query)
        print(f"\n[{session_id}] Query: {query[:60]}...")
        print(f"[{session_id}] Routed to: {routing['agent']} | Priority: {routing['priority']} | Confidence: {routing['confidence']:.0%}")
        print(f"[{session_id}] Reason: {routing['reason']}")

        # Step 2: Agent invocation
        agent = self.AGENTS[routing["agent"]]
        result = agent.invoke(query)

        # Step 3: SLA check
        latency_ms = (time.time() - start) * 1000
        sla_breached = latency_ms > routing["sla_ms"]
        if sla_breached:
            print(f"[{session_id}] ⚠️  SLA BREACH: {latency_ms:.0f}ms > {routing['sla_ms']}ms")
        else:
            print(f"[{session_id}] ✅ SLA OK: {latency_ms:.1f}ms < {routing['sla_ms']}ms")

        print(f"[{session_id}] Result: {result['result']}")

        # Step 4: Build trace for observability
        state: AgentState = {
            "session_id": session_id,
            "query": query,
            "query_type": routing["query_type"],
            "routing_reason": routing["reason"],
            "agent_response": result["response"],
            "tool_calls": result.get("tools_called", []),
            "latency_ms": round(latency_ms, 2),
            "errors": [] if not sla_breached else [f"SLA breached: {latency_ms:.0f}ms"],
            "timestamp": datetime.utcnow().isoformat(),
        }

        self.run_traces.append(state)
        return state

    def get_observability_report(self) -> dict:
        """Lifecycle observability report — Accenture JD requirement"""
        if not self.run_traces:
            return {"status": "no_traces"}

        return {
            "total_runs": len(self.run_traces),
            "avg_latency_ms": round(sum(t["latency_ms"] for t in self.run_traces) / len(self.run_traces), 1),
            "sla_breach_rate": round(sum(1 for t in self.run_traces if t["errors"]) / len(self.run_traces), 3),
            "query_type_distribution": {
                qt: sum(1 for t in self.run_traces if t["query_type"] == qt)
                for qt in set(t["query_type"] for t in self.run_traces)
            },
            "unique_sessions": len(set(t["session_id"] for t in self.run_traces)),
            "tools_invoked": list(set(
                tool for t in self.run_traces for tool in t["tool_calls"]
            )),
        }


# ── Demo ──────────────────────────────────────────────────────────────────────

if __name__ == "__main__":
    orchestrator = SupervisorOrchestrator()

